        "source_strategy": "VisionExtractor",
        "text_blocks": [
          {
            "text": "PROFILE",
            "bbox": [
              0.025,
              0.036,
              0.117,
              0.067
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 1
          },
          {
            "text": "\u205e Has been serving Ethiopia since 1942.",
            "bbox": [
              0.026,
              0.067,
              0.661,
              0.082
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 2
          },
          {
            "text": "\u205e Pioneered ATM services in Ethiopia.",
            "bbox": [
              0.026,
              0.082,
              0.35,
              0.097
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 3
          },
          {
            "text": "\u205e Introduced Western Union Money Transfer Services to Ethiopia.",
            "bbox": [
              0.026,
              0.097,
              0.669,
              0.113
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 4
          },
          {
            "text": "\u205e Is the first Ethiopian bank to offer interest-free banking services.",
            "bbox": [
              0.026,
              0.113,
              0.668,
              0.128
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 5
          },
          {
            "text": "\u205e Has been playing a catalytic role in the socio-economic development of the nation.",
            "bbox": [
              0.026,
              0.128,
              0.755,
              0.143
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 6
          },
          {
            "text": "\u205e Had 1,942 branches across the country as of 30 June 2024.",
            "bbox": [
              0.026,
              0.143,
              0.867,
              0.157
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 7
          },
          {
            "text": "\u205e Has strong correspondent relationships with about 38 renowned foreign banks and SWIFT bilateral key arrangements with over 750 banks.",
            "bbox": [
              0.026,
              0.157,
              0.926,
              0.176
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 8
          },
          {
            "text": "\u205e Achieved a strong asset position of Birr 1.4 trillion as of 30 June 2024.",
            "bbox": [
              0.026,
              0.176,
              0.783,
              0.192
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 9
          },
          {
            "text": "\u205e Combines a wide capital base with above 48 thousand permanent and 33 thousand temporary employees.",
            "bbox": [
              0.026,
              0.192,
              0.765,
              0.207
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 10
          },
          {
            "text": "\u205e Is headquartered in a modern skyscraper (4B+G+48) that is the tallest in East Africa.",
            "bbox": [
              0.026,
              0.207,
              0.726,
              0.224
            ],
            "page_number": 4,
            "source_strategy": "VisionExtractor",
            "reading_order": 11
          },
          {
